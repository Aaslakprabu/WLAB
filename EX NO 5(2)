<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Coimbatore Tech 2026 | Registration Deadline</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #00d2ff;
            --secondary: #3a7bd5;
            --bg-dark: #0f172a;
            --card-bg: rgba(255, 255, 255, 0.03);
            --accent-green: #10b981;
            --accent-red: #ff4d4d;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }

        body {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            color: #ffffff;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .container { text-align: center; max-width: 850px; width: 100%; transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1); }

        /* MNC Brand Header */
        .header-section h1 {
            font-size: 3rem;
            font-weight: 800;
            background: linear-gradient(to right, #00d2ff, #2563eb);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 5px;
            letter-spacing: -1.5px;
        }

        .location-tag {
            color: #94a3b8;
            font-size: 1.1rem;
            font-weight: 400;
            margin-bottom: 2rem;
            text-transform: uppercase;
            letter-spacing: 3px;
        }

        /* Countdown Grid - Premium State */
        .countdown-container {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 3.5rem;
        }

        .time-box {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            padding: 2rem 10px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            transition: transform 0.3s ease;
        }

        .time-box:hover { transform: scale(1.02); border-color: var(--primary); }

        .number { display: block; font-size: 3.5rem; font-weight: 800; color: #fff; line-height: 1; }
        .label { display: block; font-size: 0.75rem; text-transform: uppercase; color: #64748b; margin-top: 10px; font-weight: 600; }

        /* Dynamic Workflow Card */
        .workflow-card {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.05);
            padding: 3rem;
            border-radius: 30px;
            min-height: 350px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        input {
            width: 100%;
            padding: 16px;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            color: white;
            font-size: 1rem;
            margin-bottom: 15px;
            transition: border-color 0.3s;
        }

        input:focus { border-color: var(--primary); outline: none; background: rgba(255, 255, 255, 0.05); }

        .btn-action {
            width: 100%;
            padding: 18px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border: none;
            border-radius: 12px;
            color: white;
            font-weight: 700;
            font-size: 1.1rem;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(0, 210, 255, 0.2);
        }

        /* Success & Loading Visuals */
        .hidden { display: none !important; }
        
        .spinner {
            border: 4px solid rgba(255,255,255,0.05);
            border-top: 4px solid var(--primary);
            border-radius: 50%;
            width: 50px;
            height: 50px;
            animation: spin 0.8s linear infinite;
            margin: 0 auto 25px;
        }

        .success-icon {
            width: 80px;
            height: 80px;
            background: rgba(16, 185, 129, 0.1);
            color: var(--accent-green);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            margin: 0 auto 20px;
        }

        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        
        #status-alert { margin-bottom: 1.5rem; font-weight: 600; height: 30px; letter-spacing: 0.5px; }
        .closed { color: var(--accent-red); font-size: 1.8rem; text-transform: uppercase; font-weight: 800; }
        .warning { color: coral; animation: blink 1s infinite; }
        @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }

    </style>
</head>
<body>

    <div class="container">
        <div class="header-section">
            <h1>Coimbatore Tech Summit '26</h1>
            <div class="location-tag">CODISSIA Complex • May 21, 2026 Closing</div>
        </div>

        <div class="countdown-container">
            <div class="time-box"><span class="number" id="days">00</span><span class="label">Days</span></div>
            <div class="time-box"><span class="number" id="hours">00</span><span class="label">Hours</span></div>
            <div class="time-box"><span class="number" id="minutes">00</span><span class="label">Minutes</span></div>
            <div class="time-box"><span class="number" id="seconds">00</span><span class="label">Seconds</span></div>
        </div>

        <div id="status-alert"></div>

        <div class="workflow-card">
            <!-- Initial State: Registration -->
            <div id="ui-initial">
                <input type="text" id="dev-name" placeholder="Full Name (as per ID)">
                <input type="email" id="dev-email" placeholder="Corporate/University Email">
                <button class="btn-action" id="main-btn" onclick="startWorkflow()">Secure Spot in Coimbatore</button>
            </div>

            <!-- Loading State: Workings -->
            <div id="ui-loading" class="hidden">
                <div class="spinner"></div>
                <p id="loading-msg" style="color: #94a3b8; font-family: monospace;">Initializing Handshake...</p>
            </div>

            <!-- Success State: Closing -->
            <div id="ui-success" class="hidden">
                <div class="success-icon">✓</div>
                <h2 style="font-weight: 800; margin-bottom: 10px;">Entrance Secured</h2>
                <p style="color: #94a3b8; margin-bottom: 20px;">Your digital pass has been queued for delivery.</p>
                <div style="background: rgba(255,255,255,0.05); padding: 15px; border-radius: 8px; border: 1px dashed #444;">
                    <span style="font-size: 0.8rem; color: #64748b; display: block; margin-bottom: 5px;">REFERENCE TOKEN</span>
                    <span id="token-id" style="font-family: monospace; font-size: 1.4rem; color: var(--primary); font-weight: 700;">CBE-2026-X8B2</span>
                </div>
                <button style="margin-top:25px; background: transparent; border: 1px solid #334155; color: #64748b; cursor: pointer; padding: 10px; border-radius: 8px;" onclick="location.reload()">Back to Counter</button>
            </div>
        </div>
    </div>

    <script>
        // SET TARGET: May 21, 2026 at Midnight
        const closingDate = new Date("May 21, 2026 00:00:00").getTime();

        const countdownHandler = setInterval(updateDisplay, 1000);

        function updateDisplay() {
            const now = new Date().getTime();
            const timeRemaining = closingDate - now;

            // Calculations
            const d = Math.floor(timeRemaining / (1000 * 60 * 60 * 24));
            const h = Math.floor((timeRemaining % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const m = Math.floor((timeRemaining % (1000 * 60 * 60)) / (1000 * 60));
            const s = Math.floor((timeRemaining % (1000 * 60)) / 1000);

            // Display Updates
            document.getElementById('days').innerText = String(d).padStart(2, '0');
            document.getElementById('hours').innerText = String(h).padStart(2, '0');
            document.getElementById('minutes').innerText = String(m).padStart(2, '0');
            document.getElementById('seconds').innerText = String(s).padStart(2, '0');

            // TC Logic: Expiry & Warning
            const alertBox = document.getElementById('status-alert');
            
            if (timeRemaining < 0) {
                clearInterval(countdownHandler);
                alertBox.innerHTML = "Registration Closed";
                alertBox.className = "closed";
                document.getElementById('main-btn').disabled = true;
                document.getElementById('main-btn').innerText = "Deadline Passed";
                document.getElementById('main-btn').style.opacity = "0.5";
            } else if (timeRemaining < (24 * 60 * 60 * 1000)) { // Less than 24 hours
                alertBox.innerHTML = "⚠️ CAPACITY ALMOST FULL - REGISTER NOW";
                alertBox.className = "warning";
            }
        }

        function startWorkflow() {
            const name = document.getElementById('dev-name').value;
            const email = document.getElementById('dev-email').value;

            if(!name || !email) {
                alert("Identity verification required for Coimbatore nodes.");
                return;
            }

            // Transition to Workings
            document.getElementById('ui-initial').classList.add('hidden');
            document.getElementById('ui-loading').classList.remove('hidden');

            const workflowSteps = [
                "Connecting to Coimbatore Regional Node...",
                "Syncing with CODISSIA database...",
                "Allocating local entrance token...",
                "Verifying credentials against whitelist...",
                "Finalizing registration packet..."
            ];

            let i = 0;
            const flowInterval = setInterval(() => {
                if(i < workflowSteps.length) {
                    document.getElementById('loading-msg').innerText = workflowSteps[i];
                    i++;
                } else {
                    clearInterval(flowInterval);
                    completeWorkflow();
                }
            }, 800);
        }

        function completeWorkflow() {
            const randIdx = Math.floor(1000 + Math.random() * 9000);
            document.getElementById('token-id').innerText = `CBE-2026-${randIdx}`;
            
            document.getElementById('ui-loading').classList.add('hidden');
            document.getElementById('ui-success').classList.remove('hidden');
        }

        updateDisplay(); // Trigger instantly
    </script>
</body>
</html>
