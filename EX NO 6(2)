<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Secure Event Registration</title>
    <!-- Modern Tech Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <style>
        :root {
            --primary: #0061FF;
            --error: #dc3545;
            --success: #28a745;
            --bg: #F8F9FB;
            --text: #1A1D23;
        }

        body { 
            font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text);
            display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0;
        }

        .form-card { 
            background: white; padding: 40px; border-radius: 20px; 
            box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1); width: 100%; max-width: 450px;
        }

        h2 { font-weight: 700; margin-bottom: 24px; text-align: center; }
        
        .form-group { margin-bottom: 18px; position: relative; }
        label { display: block; font-weight: 600; font-size: 0.85rem; margin-bottom: 6px; color: #64748B; }
        
        input { 
            width: 100%; padding: 12px 16px; border-radius: 10px;
            border: 1px solid #E2E8F0; box-sizing: border-box; font-size: 1rem; transition: all 0.2s;
        }

        /* Task: Readonly styling */
        input[readonly] { background-color: #F1F5F9; color: #64748B; cursor: not-allowed; border-style: dashed; }

        /* Error Message Style */
        .error-msg { font-size: 0.75rem; color: var(--error); margin-top: 4px; display: none; }
        
        /* Success Message Style */
        #status-message { font-weight: 600; text-align: center; margin-bottom: 15px; padding: 10px; border-radius: 8px; display: none;}

        .btn-group { display: flex; gap: 10px; margin-top: 20px; }
        
        button { 
            flex: 1; padding: 14px; border-radius: 10px; font-weight: 700; cursor: pointer; border: none; transition: 0.2s;
        }

        #submitBtn { background: var(--primary); color: white; }
        #submitBtn:disabled { background: #cbd5e1; cursor: not-allowed; }

        #resetBtn { background: #f1f5f9; color: #64748B; border: 1px solid #E2E8F0; }
        #resetBtn:hover { background: #e2e8f0; }

    </style>
</head>
<body>

    <div class="form-card">
        <h2>Register Your Spot</h2>
        <div id="status-message"></div>

        <form id="regForm">
            <div class="form-group">
                <label>Participant Name</label>
                <input type="text" id="pName" placeholder="Enter Full Name">
                <div class="error-msg" id="nameErr">Name is required.</div>
            </div>

            <div class="form-group">
                <label>Email Address</label>
                <input type="text" id="pEmail" placeholder="name@company.com">
                <div class="error-msg" id="emailErr">Please enter a valid email address.</div>
            </div>

            <div class="form-group">
                <label>Event Name (Auto-selected)</label>
                <input type="text" id="pEvent" readonly>
            </div>

            <div class="form-group">
                <label>Mobile Number</label>
                <input type="text" id="pMobile" placeholder="e.g. 9876543210">
                <div class="error-msg" id="mobileErr">Enter exactly 10 digits (numbers only).</div>
            </div>

            <div class="btn-group">
                <button type="button" id="submitBtn">Submit</button>
                <button type="button" id="resetBtn">Reset</button>
            </div>
        </form>
    </div>

    <script>
        $(document).ready(function() {
            // STEP 1: Get data passed from the first page
            const params = new URLSearchParams(window.location.search);
            const eventTitle = params.get('event');
            if(eventTitle) {
                $("#pEvent").val(eventTitle);
            }

            // STEP 2: Logic for Submit Button
            $("#submitBtn").click(function() {
                // Task: Retrieve values using jQuery methods
                const name = $("#pName").val().trim();
                const email = $("#pEmail").val().trim();
                const mobile = $("#pMobile").val().trim();
                
                // Validation Patterns
                const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                const mobileRegex = /^[0-9]{10,}$/; // Digits only, min 10

                let isValid = true;

                // --- Validation Logic ---

                // Name Validation
                if (name === "") {
                    $("#pName").css("border-color", "red");
                    $("#nameErr").css("display", "block");
                    isValid = false;
                } else {
                    $("#pName").css("border-color", "#E2E8F0");
                    $("#nameErr").hide();
                }

                // Email Validation
                if (!emailRegex.test(email)) {
                    $("#pEmail").css("border-color", "red");
                    $("#emailErr").css("display", "block");
                    isValid = false;
                } else {
                    $("#pEmail").css("border-color", "#E2E8F0");
                    $("#emailErr").hide();
                }

                // Mobile Validation
                if (!mobileRegex.test(mobile)) {
                    $("#pMobile").css("border-color", "red");
                    $("#mobileErr").css("display", "block");
                    isValid = false;
                } else {
                    $("#pMobile").css("border-color", "#E2E8F0");
                    $("#mobileErr").hide();
                }

                // --- Completion Logic ---
                if (isValid) {
                    // Task: Display successful message in green
                    $("#status-message")
                        .text("Registration Successful for " + name)
                        .css({"color": "white", "background-color": "#28a745", "display": "block"});

                    // Task: Disable button and change text
                    $(this).prop("disabled", true).text("Registered");

                    // Optional: Fade out error messages just in case
                    $(".error-msg").hide();
                }
            });

            // STEP 3: Logic for Reset Button
            $("#resetBtn").click(function() {
                // Task: Clear all fields (keep event name as it's passed data)
                $("#pName, #pEmail, #pMobile").val("");
                
                // Task: Remove error/status messages and reset styles
                $(".error-msg").hide();
                $("#status-message").hide();
                $("input").css("border-color", "#E2E8F0");
                
                // Task: Re-enable submit button
                $("#submitBtn").prop("disabled", false).text("Submit");
            });
        });
    </script>
</body>
</html>
