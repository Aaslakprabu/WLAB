<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Enterprise Quiz Assessment</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-blue: #2563eb;
            --accent-teal: #0d9488;
            --bg-gradient: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
            --warning-red: #ef4444;
            --glass-white: rgba(255, 255, 255, 0.95);
            --shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
        }

        * { box-sizing: border-box; font-family: 'Inter', sans-serif; }

        body {
            background: var(--bg-gradient);
            min-height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .assessment-wrapper {
            width: 100%;
            max-width: 900px;
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 20px;
        }

        /* Sidebar Stats */
        .sidebar {
            background: var(--glass-white);
            padding: 25px;
            border-radius: 16px;
            box-shadow: var(--shadow);
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .timer-circle {
            width: 120px;
            height: 120px;
            border: 6px solid #f1f5f9;
            border-top-color: var(--primary-blue);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto;
            font-size: 1.5rem;
            font-weight: 700;
            color: #1e293b;
        }

        /* Main Content */
        main {
            background: var(--glass-white);
            border-radius: 16px;
            box-shadow: var(--shadow);
            overflow: hidden;
            position: relative;
        }

        .progress-bar-container {
            height: 6px;
            background: #f1f5f9;
            width: 100%;
        }

        #progress-fill {
            height: 100%;
            width: 100%;
            background: var(--primary-blue);
            transition: width 1s linear;
        }

        .content-body { padding: 40px; }

        .question-card {
            display: none; /* Managed by JS */
            animation: fadeIn 0.4s ease-out;
        }

        .question-card.active { display: block; }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        h2 { margin-top: 0; font-size: 1.25rem; color: #0f172a; line-height: 1.5; }

        .options-group { margin-top: 25px; display: flex; flex-direction: column; gap: 12px; }

        .option-label {
            display: flex;
            align-items: center;
            padding: 16px;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .option-label:hover { border-color: var(--primary-blue); background: #eff6ff; }

        input[type="radio"] { margin-right: 15px; width: 18px; height: 18px; cursor: pointer; }

        /* Statuses */
        #warning-msg {
            color: var(--warning-red);
            font-weight: 600;
            font-size: 0.875rem;
            text-align: center;
            min-height: 20px;
        }

        .btn-submit {
            width: 100%;
            padding: 16px;
            background: var(--primary-blue);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            margin-top: 30px;
            transition: opacity 0.3s;
        }

        .btn-submit:disabled { opacity: 0.6; cursor: not-allowed; }

        #results-screen {
            display: none;
            text-align: center;
            padding: 40px;
        }

        .score-badge {
            font-size: 3rem;
            font-weight: 800;
            color: var(--accent-teal);
            margin: 20px 0;
        }

        @media (max-width: 768px) {
            .assessment-wrapper { grid-template-columns: 1fr; }
            .sidebar { order: -1; }
        }
    </style>
</head>
<body>

<div class="assessment-wrapper">
    <aside class="sidebar">
        <div style="text-align: center;">
            <p style="text-transform: uppercase; font-size: 0.75rem; letter-spacing: 1px; color: #64748b; font-weight: 700; margin-bottom: 10px;">Time Remaining</p>
            <div class="timer-circle" id="timer-text">60</div>
        </div>
        <div id="warning-msg"></div>
        <hr style="border: 0; border-top: 1px solid #e2e8f0; width: 100%;">
        <div style="font-size: 0.875rem; color: #475569;">
            <strong>Module:</strong> Quiz Application <br>
            <strong>Questions:</strong> 5 MCQs
        </div>
    </aside>

    <main id="main-content">
        <div class="progress-bar-container">
            <div id="progress-fill"></div>
        </div>

        <div class="content-body" id="quiz-body">
            <div id="question-container">
                <div class="question-card active">
                    <h2>1. Which method is used to stop a timer created by <code>setInterval()</code>? </h2>
                    <div class="options-group">
                        <label class="option-label"><input type="radio" name="q1" value="A"> stopInterval()</label>
                        <label class="option-label"><input type="radio" name="q1" value="B"> clearInterval()</label>
                        <label class="option-label"><input type="radio" name="q1" value="C"> deleteInterval()</label>
                    </div>
                </div>

                <div class="question-card">
                    <h2>2. How do you store correct answers for efficient access in JavaScript? </h2>
                    <div class="options-group">
                        <label class="option-label"><input type="radio" name="q2" value="A"> In an Object</label>
                        <label class="option-label"><input type="radio" name="q2" value="B"> In a CSS file</label>
                        <label class="option-label"><input type="radio" name="q2" value="C"> In an HTML tag</label>
                    </div>
                </div>

                <div class="question-card">
                    <h2>3. What property prevents a user from changing an option after submission? </h2>
                    <div class="options-group">
                        <label class="option-label"><input type="radio" name="q3" value="A"> invisible</label>
                        <label class="option-label"><input type="radio" name="q3" value="B"> frozen</label>
                        <label class="option-label"><input type="radio" name="q3" value="C"> disabled</label>
                    </div>
                </div>

                <div class="question-card">
                    <h2>4. Which method updates the UI dynamically without a page reload? [cite: 2]</h2>
                    <div class="options-group">
                        <label class="option-label"><input type="radio" name="q4" value="A"> Browser Refresh</label>
                        <label class="option-label"><input type="radio" name="q4" value="B"> DOM Manipulation</label>
                        <label class="option-label"><input type="radio" name="q4" value="C"> HTTP Redirect</label>
                    </div>
                </div>

                <div class="question-card">
                    <h2>5. What is the correct timing function for a countdown timer? </h2>
                    <div class="options-group">
                        <label class="option-label"><input type="radio" name="q5" value="A"> setInterval()</label>
                        <label class="option-label"><input type="radio" name="q5" value="B"> setTimeout()</label>
                        <label class="option-label"><input type="radio" name="q5" value="C"> requestFrame()</label>
                    </div>
                </div>
            </div>

            <button class="btn-submit" id="submit-btn" onclick="submitQuiz()">Complete Assessment</button>
        </div>

        <div id="results-screen">
            <h2 style="font-size: 1.5rem;">Assessment Complete</h2>
            <p style="color: #64748b;">Your final score is calculated below:</p>
            <div class="score-badge" id="score-text">0/5</div>
            <p id="result-status"></p>
        </div>
    </main>
</div>

<script>
    // Configuration based on TC01 & TC06 
    const correctAnswers = { q1: "B", q2: "A", q3: "C", q4: "B", q5: "A" };
    let timeLeft = 60; // 1 Minute
    let timerId;

    // TC01: Initialization 
    window.onload = function() {
        startTimer();
        setupQuestionNavigation();
    };

    function startTimer() {
        timerId = setInterval(() => {
            timeLeft--;
            
            // TC02: Update Timer 
            document.getElementById("timer-text").innerText = timeLeft;
            
            // Progress bar calculation
            const progress = (timeLeft / 60) * 100;
            document.getElementById("progress-fill").style.width = `${progress}%`;

            // TC03: Warning Message at 5 seconds 
            if (timeLeft === 5) {
                document.getElementById("warning-msg").innerText = "⚠️ Only 5 seconds remaining!";
                document.getElementById("timer-text").style.color = "var(--warning-red)";
            }

            // TC04: Auto Submission 
            if (timeLeft <= 0) {
                submitQuiz();
            }
        }, 1000);
    }

    function submitQuiz() {
        // TC05: Clear Timer 
        clearInterval(timerId);
        
        let score = 0;
        const inputs = document.querySelectorAll('input[type="radio"]');

        // TC07: Score Calculation 
        for (let key in correctAnswers) {
            const selected = document.querySelector(`input[name="${key}"]:checked`);
            if (selected && selected.value === correctAnswers[key]) {
                score++;
            }
        }

        // TC08: Disable Inputs 
        inputs.forEach(input => input.disabled = true);
        document.getElementById("submit-btn").disabled = true;

        // TC09: DOM Update [cite: 2]
        document.getElementById("quiz-body").style.display = "none";
        document.getElementById("results-screen").style.display = "block";
        document.getElementById("score-text").innerText = `${score} / 5`;
        document.getElementById("progress-fill").style.backgroundColor = "var(--accent-teal)";
        document.getElementById("warning-msg").innerText = "Submitted successfully.";
    }

    // Optional UI enhancement: show one question at a time (Auto-Next)
    function setupQuestionNavigation() {
        const labels = document.querySelectorAll('.option-label');
        const cards = document.querySelectorAll('.question-card');
        let currentIdx = 0;

        labels.forEach(label => {
            label.addEventListener('click', () => {
                if(currentIdx < cards.length - 1) {
                    setTimeout(() => {
                        cards[currentIdx].classList.remove('active');
                        currentIdx++;
                        cards[currentIdx].classList.add('active');
                    }, 300);
                }
            });
        });
    }
</script>

</body>
</html>
